$mailsms_query5 = "INSERT INTO `wiz_mailsms` (`code`, `type`, `subject`, `sms_send`, `sms_oper`, `sms_msg`, `email_subj`, `email_send`, `email_oper`, `email_msg`, `alim_msg`, `wdate`) VALUES ('mem_dormancy_email','MEM','휴면해제 이메일인증시','','N','[{SITE_NAME}] 회원님 아이디가 휴면해제되었습니다. 신규비밀번호 : {MEM_PW}','[{SITE_NAME}] 휴면해제 이메일인증 메일입니다.','Y','N','<table width=\\\"642\\\" height=\\\"100%\\\" align=\\\"center\\\" border=\\\"0\\\" cellspacing=\\\"0\\\" cellpadding=\\\"0\\\">\r\n   <tbody>\r\n      <tr>\r\n         <td>\r\n            <table border=\\\"0\\\" cellspacing=\\\"0\\\" cellpadding=\\\"0\\\">\r\n               <tbody>\r\n                  <tr>\r\n                     <td><img alt=\\\"\\\" src=\\\"{SITE_URL}/twcenter/mail/img/top_01.gif\\\" /></td>\r\n                     </tr>\r\n                  <tr>\r\n                     <td background=\\\"{SITE_URL}/twcenter/mail/img/bg_line.gif\\\">\r\n                        <table width=\\\"642\\\" border=\\\"0\\\" cellspacing=\\\"0\\\" cellpadding=\\\"0\\\">\r\n                           <tbody>\r\n                              <tr>\r\n                                 <td style=\\\"padding: 10px\\\">{MEM_NAME} 고객님 안녕하세요.<br />저희 {SITE_NAME}를 이용해 주셔서 감사합니다.<br /><br />휴면해제를 위한 이메일 인증입니다.<br />로그인시 새로 발급된 비밀번호를 통해 로그인 하신후<br />비밀번호를 변경하시기 바랍니다.<br /><br />신규 비밀번호 : {MEM_PW}<br /><br /><br />\r\n                                    <p style=\\\"text-align: center;\\\"><a href=\\\"{LINK}\\\" target=\\\"_blank\\\" style=\\\"display:inline-block; padding:15px 20px; text-decoration:none; font-weight:600; color:#fff; background:#0050be;\\\">{SITE_NAME} 로그인하기</a></p>\r\n                                    </td>\r\n                                 </tr>\r\n                              <tr>\r\n                                 <td height=\\\"15\\\"></td>\r\n                                 </tr>\r\n                              <tr>\r\n                                 <td style=\\\"padding: 10px\\\">\r\n                                    <table width=\\\"100%\\\" border=\\\"0\\\" cellspacing=\\\"0\\\" cellpadding=\\\"0\\\">\r\n                                       <tbody>\r\n                                          <tr>\r\n                                             <td height=\\\"30\\\" valign=\\\"top\\\"><strong>개인정보 보호를 위한 관련법령</strong></td>\r\n                                             </tr>\r\n                                          <tr>\r\n                                             <td style=\\\"height:1px; padding:0; margin:0; font-size:0; line-height:0;\\\" bgcolor=\\\"#cccccc\\\"></td>\r\n                                             </tr>\r\n                                          <tr>\r\n                                             <td bgcolor=\\\"#f4f4f4\\\" height=\\\"20\\\"></td>\r\n                                             </tr>\r\n                                          <tr>\r\n                                             <td style=\\\"padding:0 10px; Margin:0; font-weight:normal; font-size:11px; color:#707070; line-height:15px\\\" bgcolor=\\\"#f4f4f4\\\"> 제29조(개인정보의 파기)<br />② 정보통신서비스 제공자등은 정보통신서비스를 1년의 기간 동안 이용하지 아니하는 이용자의 개인정보를 보호하기 위하여 대통령령으로 정하는 바에 따라 개인정보의 파기 등 필요한 조치를 취하여야 한다. 다만, 그 기간에 대하여 다른 법령 또는 이용자의 요청에 따라 달리 정한 경우에는 그에 따른다. &lt;신설 2012.2.17, 2015.12.1&gt; </td>\r\n                                             </tr>\r\n                                          <tr>\r\n                                             <td style=\\\"width:100%; height:20px; Margin:0; padding:0\\\" height=\\\"20\\\" bgcolor=\\\"#f4f4f4\\\"></td>\r\n                                             </tr>\r\n                                          <tr>\r\n                                             <td style=\\\"padding:0 10px; Margin:0; font-weight:normal; font-size:11px; color:#707070; line-height:15px\\\" bgcolor=\\\"#f4f4f4\\\"> 시행령 제16조(개인정보파기 등)<br />② 정보통신서비스 제공자등은 이용자가 정보통신서비스를 법 제29조 제2항의 기간 동안 이용하지 아니하는 경우에는 이용자의 개인정보를 해당 기간 경과 후 즉시 파기하거나 다른 이용자의 개인정보와 분리하여 별도로 저장·관리하여야 한다. <br />&lt;개정 2016.5.31&gt; </td>\r\n                                             </tr>\r\n                                          <tr>\r\n                                             <td height=\\\"20\\\" bgcolor=\\\"#f4f4f4\\\"></td>\r\n                                             </tr>\r\n                                          <tr>\r\n                                             <td style=\\\"height:1px; padding:0; margin:0; font-size:0; line-height:0;\\\" bgcolor=\\\"#cccccc\\\"></td>\r\n                                             </tr>\r\n                                          </tbody>\r\n                                       </table>\r\n                                    </td>\r\n                                 </tr>\r\n                              <tr>\r\n                                 <td height=\\\"15\\\"></td>\r\n                                 </tr>\r\n                              </tbody>\r\n                           </table>\r\n                        </td>\r\n                     </tr>\r\n                  <tr>\r\n                     <td><img alt=\\\"\\\" src=\\\"{SITE_URL}/twcenter/mail/img/bottom.gif\\\" /></td>\r\n                     </tr>\r\n                  </tbody>\r\n               </table>\r\n            </td>\r\n         </tr>\r\n      </tbody>\r\n   </table>\r\n', '', now());";
